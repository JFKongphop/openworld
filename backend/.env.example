# ========================================
# 0G Network Configuration
# ========================================

# 0G Compute endpoint (OpenAI-compatible chat API)
OG_COMPUTE_ENDPOINT=https://compute-network-6.integratenetwork.work/v1/proxy/chat/completions

# 0G Compute model
OG_COMPUTE_MODEL=qwen/qwen-2.5-7b-instruct

# 0G Compute API key (Bearer token)
OG_COMPUTE_API_KEY=app-sk-...

# 0G Storage indexer RPC
OG_INDEXER_RPC=https://indexer-storage-turbo.0g.ai

# 0G Storage stream ID for travel data
OG_STORAGE_STREAM_ID=openworld_travel

# Path to 0g-cli binary
OG_CLI_PATH=./0g-cli

# Path to manifest.json for storage uploads
OG_MANIFEST_PATH=./manifest.json

# ========================================
# Agent Configuration
# ========================================

# Firecrawl API key (for SearchAgent — web scraping)
FIRECRAWL_API_KEY=fc-...

# OpenClaw endpoint (for ReservationAgent — browser automation)
# Leave blank to run in simulation/demo mode
OPENCLAW_ENDPOINT=http://localhost:4000

# ========================================
# Blockchain (ERC-7857 Journey Artifact)
# ========================================

# 0G Mainnet RPC
OG_RPC_URL=https://evmrpc.0g.ai

# Deployed OpenWorldJourney ERC-7857 contract address
JOURNEY_CONTRACT_ADDRESS=0x...

# Agent operator wallet private key
OPERATOR_PRIVATE_KEY=0x...

# ========================================
# Server
# ========================================
PORT=3000
